# Django
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_SITE_URL=http://127.0.0.1:8000

# Database (sqlite or postgresql)
DJANGO_SELECTED_DB=sqlite

# PostgreSQL
POSTGRES_DB=cutanix_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
# true  -> кэш и throttling через Redis (нужно для Docker/прода)
# false -> локальный LocMemCache (простой локальный запуск)
DJANGO_USE_REDIS=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=cutanix_redis_pass
# true -> Celery выполняет задачи синхронно (без воркера/Redis)
CELERY_ALWAYS_EAGER=false

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHANNEL_ID=your-channel-id-here
# Публичный username канала (без @) — по нему строится ссылка-приглашение
TELEGRAM_CHANNEL_USERNAME=your-channel-username
# Администраторы (Telegram ID через запятую): 123456789,987654321
ADMIN_TELEGRAM_IDS=

# AI APIs (оставьте пустыми для отключения)
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=

# Rate limiting (защита от спама)
THROTTLE_USER_RATE=120/min
THROTTLE_ANON_RATE=30/min
THROTTLE_ANALYSIS_BURST=10/min
THROTTLE_ANALYSIS_SUSTAINED=100/day

# Superuser (создаётся автоматически при первом запуске)
DJANGO_SUPERUSER_NAME=admin
DJANGO_SUPERUSER_EMAIL=admin@cutanix.ru
DJANGO_SUPERUSER_PASSWORD=cutanix_admin_pass

# Certbot (для prod-nginx, авто-генерация SSL через jonasal/nginx-certbot)
CUTANIX_DOMAIN=yourdomain.com
# 1 = тестовые сертификаты (без лимитов Let's Encrypt), 0 = боевые
CERTBOT_STAGING=0
CERTBOT_EMAIL=admin@yourdomain.com
